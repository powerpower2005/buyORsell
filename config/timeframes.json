      "googleWindow": "1D",
      "googleChartMode": 1,
      "enabled": false,
      "maxBars": 500
    },
    "1h": {
      "label": "1시간",
      "intervalSeconds": 3600,
      "googleWindow": "5D",
      "googleChartMode": 4,
      "enabled": false,
      "maxBars": 200
    },
    "4h": {
      "label": "4시간",
      "intervalSeconds": 14400,
      "aggregateFrom": "1h",
      "aggregateRule": "ohlcv_bucket",
      "enabled": false,
      "maxBars": 200
    },
    "1d": {
      "label": "일봉",
      "intervalSeconds": 86400,
      "googleWindow": "2Y",
      "googleChartMode": 7,
