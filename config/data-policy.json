{
  "schemaVersion": 1,
  "fetchScriptVersion": "1.0.0",
  "defaultWindow": "1Y",
  "freshness": {
    "maxAgeHours": 24,
    "maxTradingDayLag": 3,
    "minBarCount": 50
  },
  "accuracy": {
    "spotCheckLatestClose": true,
    "closeTolerancePct": 1.0,
    "volumeTolerancePct": 10.0
  },
  "update": {
    "strategy": "incremental_merge",
    "shortFetchWindowForUpdate": "5D",
    "skipCommitIfNoDiff": false
  },
  "freshnessByTimeframe": {
    "15m": { "freshnessMode": "maxAge", "maxAgeHours": 1 },
    "1h": { "freshnessMode": "maxAge", "maxAgeHours": 4 },
    "4h": { "freshnessMode": "maxAge", "maxAgeHours": 8 },
    "1d": { "freshnessMode": "tradingDay" },
    "1w": { "freshnessMode": "tradingDay" }
  }
}
