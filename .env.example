# Required for raw URL + Issue links
VITE_GITHUB_REPO=powerpower2005/buyORsell
VITE_GITHUB_BRANCH=main

# --- OHLCV fetch (Sheets backend) ---
# Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit
GOOGLE_SHEET_ID=

# Path to service account JSON (share the spreadsheet with client_email as Editor)
GOOGLE_SERVICE_ACCOUNT_PATH=config/service_account.json

# Or inline JSON (GitHub Actions secret)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Korean locale spreadsheet: use semicolon formula separator
# SHEETS_FORMULA_SEP=;
